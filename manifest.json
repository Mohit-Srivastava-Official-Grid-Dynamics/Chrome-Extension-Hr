{
  "manifest_version": 3,
  "name": "Timesheet Side Panel",
  "version": "1.0.0",
  "description": "Shows upcoming Google Calendar meetings in a Chrome side panel.",
  "permissions": ["identity", "storage", "alarms", "sidePanel"],
  "host_permissions": ["https://www.googleapis.com/*"],
  "action": {
    "default_title": "Open Timesheet"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "oauth2": {
    "client_id": "...",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}